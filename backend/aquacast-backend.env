# Aquacast backend runtime configuration.
# Used by `make local`, `make run`, and docker compose from this directory.

AQUACAST_BACKEND_HOST=0.0.0.0
AQUACAST_BACKEND_PORT=8765
AQUACAST_WQ_SCENARIO=baseline

# Data files. Override these when testing alternative calibration bundles.
AQUACAST_WQ_CONSTANTS=extensions/aquacast.aquacast_composer_extensions/data/wq_constants.json
AQUACAST_WQ_FEED_RATE=extensions/aquacast.aquacast_composer_extensions/data/wq_feed_rate.json
AQUACAST_WQ_SCENARIOS=extensions/aquacast.aquacast_composer_extensions/data/wq_scenarios.json

# Thermal v2 geometry and coefficients.
AQUACAST_WQ_TANK_RADIUS_M=1.2
AQUACAST_WQ_TANK_WATER_HEIGHT_M=2.21
AQUACAST_WQ_WATER_DENSITY=998.0
AQUACAST_WQ_WATER_CP=4186.0
AQUACAST_WQ_U_WALL_W_M2K=5.0
AQUACAST_WQ_EMISSIVITY=0.96
AQUACAST_WQ_AIR_TEMP_C=22.0
AQUACAST_WQ_ROOM_TEMP_C=22.0
AQUACAST_WQ_REL_HUMIDITY=0.60
AQUACAST_WQ_AIR_SPEED_MS=0.2
AQUACAST_WQ_EVAP_A_W_M2_KPA=18.0
AQUACAST_WQ_EVAP_B_W_M2_KPA_PER_MS=12.0
AQUACAST_WQ_BOWEN_GAMMA_KPA_K=0.066
AQUACAST_WQ_Q_MAKEUP_LPH=220.0
AQUACAST_WQ_INLET_TEMP_C=12.0
AQUACAST_WQ_HEATER_POWER_W=0.0

# Backend particle heat field.
AQUACAST_WQ_PARTICLE_DIFFUSION_D=0.015
AQUACAST_WQ_PARTICLE_KNN_K=8
AQUACAST_WQ_PARTICLE_BULK_RELAX_LAMBDA=0.0015
AQUACAST_WQ_PARTICLE_WALL_SOURCE_LAMBDA=0.00025
AQUACAST_WQ_PARTICLE_INLET_SOURCE_LAMBDA=0.0012
AQUACAST_WQ_PARTICLE_INLET_RADIUS_M=0.35
AQUACAST_WQ_PARTICLE_HEATER_RADIUS_M=0.4
AQUACAST_WQ_INLET_LOCATION=[-1.1,1.1,0.0]
AQUACAST_WQ_HEATER_LOCATION=[1.0,0.35,0.0]

# Kafka publisher. Set to 0 to disable publishing.
AQUACAST_KAFKA_ENABLED=1
AQUACAST_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
AQUACAST_KAFKA_TOPIC=aquacast.water_quality
AQUACAST_KAFKA_TANK_ID=tank-01
AQUACAST_KAFKA_CLIENT_ID=aquacast-wq-backend
AQUACAST_KAFKA_ACKS=1
AQUACAST_KAFKA_COMPRESSION=lz4
AQUACAST_KAFKA_LINGER_MS=50
AQUACAST_KAFKA_DELIVERY_TIMEOUT_MS=10000
AQUACAST_KAFKA_MAX_BUFFER_MESSAGES=100000
AQUACAST_KAFKA_FLUSH_ON_SHUTDOWN_SECONDS=3.0
